jubin
jubin.pub

# Large model weights (use HF mirror or local snapshot_download)
models/

# Topic runtime artifacts (if present under repo topics)
config/topics/**/evidence_sets/

# --- Virtual environments (do not commit) ---
KVI/
.venv/
venv/
env/

# --- Python bytecode / caches ---
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Editor / local ---
.DS_Store
.hf_tmp/
.vscode/
.idea/
_toy/

# --- Topic pipeline: generated corpora / KV blocks (not source) ---
config/topics/SFTSV/*.jsonl
config/topics/SFTSV/blocks*.jsonl
config/topics/SFTSV/evidence.txt
config/topics/SFTSV/kvbank_blocks/
config/topics/SFTSV/alias_map.debug.json

# --- Exp01: datasets, graph/KV tree (often a symlink to cold storage; never commit) ---
experiments/exp01_main_qa/artifacts
experiments/exp01_main_qa/data/

# Symlinked or local-heavy run tree (jsonl/csv/logs/json predictions). Paper *.md 副本见 experiments/exp01_main_qa/reports/
experiments/exp01_main_qa/results

# --- Dataset mirrors (HF/local clones; often nested git repos — never `git add`) ---
# Third-party datasets (CL-Bench, KILT, TruthfulQA mirrors, parquet, etc.) stay local only.
experiments/_mirror_data/
experiments/_mirror_data_resolved/

# --- Exp02 / Exp07: rebuildable builds (KV banks, embeddings, graph index — very large) ---
# Keep: **/code/*, **/results/* (summaries, tables, plots, small predictions), **/*.md, README
experiments/exp02_hallucination/artifacts/
experiments/exp07_clbench_longcontext/artifacts/
# Prepared eval shards (regenerate from mirrors + prepare_* scripts)
experiments/exp02_hallucination/data/
experiments/exp07_clbench_longcontext/data/

# Large binaries if ever placed under experiments/
experiments/**/*.npy
experiments/**/*.pt
experiments/**/*.parquet

# Pipeline / supervisor / nohup logs (keep summaries, csv, json, plots, *.md)
experiments/**/results/**/*.log

# --- Other experiments: local data + numeric artifacts (keep README/code/*.md) ---
experiments/exp03_retrieval_quality/data/
experiments/exp03_retrieval_quality/results/*.json
experiments/exp06_ablation/**/data/
experiments/exp06_ablation/results/**/*.json
experiments/exp06_ablation/results/**/*.jsonl
experiments/exp06_ablation/results/**/*.csv
experiments/logs/

# --- Docs: only allow PNG files and 90_experiment_runbook_linux.md ---
docs/*
